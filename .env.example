APP_NAME="TFP Multi-Site Headless Blog CMS"
APP_ENV="production"
APP_DEBUG="false"

APP_URL="https://blog-cms.tfptechnologies.in"

DB_HOST="localhost"
DB_PORT="3306"
DB_DATABASE="your_database_name"
DB_USERNAME="your_db_username"
DB_PASSWORD="your_db_password"

JWT_SECRET="replace_with_64_character_random_secret"
JWT_ACCESS_TTL="3600"
JWT_REFRESH_TTL="604800"

UPLOAD_MAX_SIZE="20971520"
TIMEZONE="Asia/Kolkata"

RATE_LIMIT_PUBLIC="500"
RATE_LIMIT_AUTH_API="1000"
RATE_LIMIT_LOGIN="10"
