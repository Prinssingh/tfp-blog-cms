{
    "name": "tfp/blog-cms",
    "description": "TFP Multi-Site Headless Blog CMS",
    "type": "project",
    "require": {
        "php": "^8.2",
        "firebase/php-jwt": "^6.10",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "audit": {
        "ignore": {
            "PKSA-y2cr-5h3j-g3ys": "firebase/php-jwt advisory — no user-supplied key material exposed in this app"
        }
    }
}
